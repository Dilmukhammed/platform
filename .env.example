# =============================================================================
# Production Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git — it's already in .gitignore.
# =============================================================================

# ── App URL (REQUIRED) ──────────────────────────────────────────────────
# Your production domain. Must be set for server-side fetch and auth redirects.
# In dev: http://localhost:3000
# In production: https://your-domain.uz
NEXT_PUBLIC_APP_URL=

# ── Supabase ─────────────────────────────────────────────────────────────
# Find these in Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth ─────────────────────────────────────────────────────────────────
# Strong random 32-byte hex string (generate: openssl rand -hex 32)
# Used for HMAC session cookie signing. REQUIRED for production.
# WARNING: Changing this invalidates all existing sessions.
AUTH_COOKIE_SECRET=

# Allow insecure cookies for local HTTP testing (dev only)
# Remove or set to 0 in production
AUTH_COOKIE_INSECURE=0

# ── AI Provider (primary — MiniMax direct API) ───────────────────────────
# Get API key: https://platform.minimax.io
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7

# ── AI Provider (fallback — Fireworks gateway) ───────────────────────────
# Only needed if you want automatic failover when MiniMax is down.
# Get API key: https://fireworks.ai
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/minimax-m2p7

# ── Upstash Redis (rate limiting — recommended for production) ───────────
# Without these, rate limiting falls back to in-memory store
# that resets on every server restart.
# Get credentials: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Optional ─────────────────────────────────────────────────────────────
# Error tracking (Sentry)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
